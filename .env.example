# ==========================================
# Application Configuration
# ==========================================

# Environment (development | production | test)
NODE_ENV=production

# Server port
PORT=3000

# ==========================================
# Storage Configuration
# ==========================================

# Storage type: memory | redis
# memory: In-memory storage (single instance only)
# redis: Redis storage (distributed, production-ready)
STORAGE_TYPE=memory

# ==========================================
# Redis Configuration (when STORAGE_TYPE=redis)
# ==========================================

# Redis host
REDIS_HOST=redis

# Redis port
REDIS_PORT=6379

# Redis external port (for local access)
REDIS_PORT_EXTERNAL=6379

# Redis password (change in production!)
REDIS_PASSWORD=changeme

# Redis database number (0-15)
REDIS_DB=0

# ==========================================
# Rate Limiter Configuration
# ==========================================

# Algorithm: TOKEN_BUCKET | SLIDING_WINDOW_COUNTER
RATE_LIMIT_ALGORITHM=TOKEN_BUCKET

# Default rate limit (requests per minute)
DEFAULT_REQUESTS_PER_MINUTE=100

# Enable global interceptor (true | false)
ENABLE_GLOBAL_INTERCEPTOR=true

# ==========================================
# AWS Configuration (for GitHub Actions deployment)
# ==========================================
# These are typically set as GitHub Secrets, not in .env
# Included here for reference only

# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_REGION=us-east-1
# ECR_REPOSITORY=rate-limiter
# ECS_CLUSTER=rate-limiter-cluster
# ECS_SERVICE=rate-limiter-service
# ECS_TASK_DEFINITION=.aws/task-definition.json

# ==========================================
# Monitoring & Observability (Optional)
# ==========================================

# Slack webhook for deployment notifications
# SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord webhook for deployment notifications
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR/WEBHOOK

# Application URL (for GitHub Actions environment)
# APP_URL=https://your-app.example.com

# ==========================================
# Logging Configuration
# ==========================================

# Log level: log | error | warn | debug | verbose
LOG_LEVEL=log

# ==========================================
# Redis UI Configuration (optional)
# ==========================================

# Redis Commander UI port
REDIS_UI_PORT=8081

# Redis Commander credentials
REDIS_UI_USER=admin
REDIS_UI_PASSWORD=admin
