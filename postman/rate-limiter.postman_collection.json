    {
      "name": "🔥 Stress Tests",
      "description": "Requests para disparar el rate limit.\n\nCómo usar:\n1. Clic derecho en la carpeta → 'Run folder'\n2. Configurar las iteraciones (ej: 15 para /api/test que tiene límite de 10)\n3. Delay: 0ms para simular ráfaga\n4. Observar los 429 en la respuesta",
      "item": [
        {
          "name": "Burst Test → /api/test (límite: 10/min)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "stress-test-client",
                "description": "Identificador custom para aislar el test"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/test",
              "host": ["{{baseUrl}}"],
              "path": ["api", "test"]
            },
            "description": "Ejecutar con Runner: **15 iteraciones, 0ms delay**\n\nLas primeras 10 devolverán 200, las siguientes 429."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const remaining = parseInt(pm.response.headers.get('X-RateLimit-Remaining') || '-1');",
                  "const status = pm.response.code;",
                  "",
                  "console.log(`Request #${pm.info.iteration + 1} → Status: ${status} | Remaining: ${remaining}`);",
                  "",
                  "if (status === 200) {",
                  "  pm.test(`[OK] Request permitido (remaining: ${remaining})`, () => {",
                  "    pm.expect(status).to.eql(200);",
                  "  });",
                  "} else if (status === 429) {",
                  "  pm.test('[BLOCKED] Rate limit alcanzado correctamente ✓', () => {",
                  "    pm.expect(status).to.eql(429);",
                  "  });",
                  "  const retryAfter = pm.response.headers.get('Retry-After');",
                  "  console.log(`Retry-After: ${retryAfter}s`);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Burst Test → /api/auth/login (límite: 5/min)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Client-Id",
                "value": "stress-test-client"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"attacker\",\n  \"password\": \"wrong_password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Ejecutar con Runner: **8 iteraciones, 0ms delay**\n\nSimula un ataque de brute force. Las primeras 5 pasan, luego bloquea."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const remaining = parseInt(pm.response.headers.get('X-RateLimit-Remaining') || '-1');",
                  "const status = pm.response.code;",
                  "",
                  "console.log(`Request #${pm.info.iteration + 1} → Status: ${status} | Remaining: ${remaining}`);",
                  "",
                  "if (status === 200) {",
                  "  pm.test(`[OK] Login permitido (remaining: ${remaining})`, () => {",
                  "    pm.expect(status).to.eql(200);",
                  "  });",
                  "} else if (status === 429) {",
                  "  pm.test('[BLOCKED] Brute force bloqueado correctamente ✓', () => {",
                  "    pm.expect(status).to.eql(429);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Check Rate Limit Headers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/feed",
              "host": ["{{baseUrl}}"],
              "path": ["api", "feed"]
            },
            "description": "Inspecciona los headers de rate limiting en detalle."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('X-RateLimit-Limit presente y es número', () => {",
                  "  const val = pm.response.headers.get('X-RateLimit-Limit');",
                  "  pm.expect(val).to.not.be.null;",
                  "  pm.expect(parseInt(val)).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('X-RateLimit-Remaining presente y >= 0', () => {",
                  "  const val = pm.response.headers.get('X-RateLimit-Remaining');",
                  "  pm.expect(val).to.not.be.null;",
                  "  pm.expect(parseInt(val)).to.be.at.least(0);",
                  "});",
                  "",
                  "pm.test('X-RateLimit-Reset presente y es timestamp futuro', () => {",
                  "  const val = pm.response.headers.get('X-RateLimit-Reset');",
                  "  pm.expect(val).to.not.be.null;",
                  "  pm.expect(parseInt(val)).to.be.above(Date.now() / 1000 - 1);",
                  "});",
                  "",
                  "// Mostrar resumen en consola",
                  "console.log('--- Rate Limit Headers ---');",
                  "console.log('Limit:    ', pm.response.headers.get('X-RateLimit-Limit'));",
                  "console.log('Remaining:', pm.response.headers.get('X-RateLimit-Remaining'));",
                  "console.log('Reset:    ', pm.response.headers.get('X-RateLimit-Reset'));",
                  "console.log('--------------------------');"
                ]
              }
            }
          ],
          "response": []
        }
      ]
